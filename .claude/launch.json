{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Backend (Express API)",
      "runtimeExecutable": "/usr/local/bin/node",
      "runtimeArgs": ["--watch", "server/src/server.js"],
      "port": 3000,
      "autoPort": false,
      "env": { "PATH": "/usr/local/bin:/usr/bin:/bin" }
    },
    {
      "name": "Frontend (Vite Dev)",
      "runtimeExecutable": "/usr/local/bin/node",
      "runtimeArgs": ["node_modules/.bin/vite", "--host"],
      "port": 5173,
      "cwd": "/Users/ludo/Mineblock-LLC/client",
      "env": { "PATH": "/usr/local/bin:/usr/bin:/bin" }
    },
    {
      "name": "Upsell Preview",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8080", "--directory", "upsells"],
      "port": 8080
    }
  ]
}
