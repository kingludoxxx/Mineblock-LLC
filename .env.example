# Mineblock Admin Dashboard — environment template
# Copy to .env and fill in real values. NEVER commit .env.
# Ask the operator for real credential values.

# ---- Core ----
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5432/mineblock_admin
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info

# ---- Auth ----
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here

# ---- Initial admin (seed) ----
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=change-me

# ---- AI providers ----
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
NANOBANANA_API_KEY=

# ---- ClickUp ----
CLICKUP_API_TOKEN=

# ---- Triple Whale (analytics) ----
TRIPLEWHALE_API_KEY=
TRIPLEWHALE_SHOP_ID=

# ---- Meta / Facebook Ads ----
META_ACCESS_TOKEN=
META_AD_ACCOUNT_IDS=
META_WEBHOOK_VERIFY_TOKEN=

# ---- Slack ----
SLACK_BOT_TOKEN=
SLACK_REJECTION_CHANNEL=

# ---- Shopify ----
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_STORE_DOMAIN=
SHOPIFY_WEBHOOK_SECRET=

# ---- Whop ----
WHOP_API_TOKEN=

# ---- Misc ----
SUPPLIER_SHARE_TOKEN=
